          "variables": {
            "$fxv#0": "{\n  \"version\": \"Notebook/1.0\",\n  \"items\": [\n    {\n      \"type\": 1,\n      \"content\": {\n        \"json\": \"# Azure Activity — Lab Overview\\nControl-plane activity ingested into this workspace through the Azure Activity connector. Adjust the time range with the workbook time picker.\"\n      },\n      \"name\": \"title\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"AzureActivity\\n| summarize Events = count() by bin(TimeGenerated, 1h)\\n| order by TimeGenerated asc\",\n        \"size\": 0,\n        \"title\": \"Activity events over time\",\n        \"timeContext\": { \"durationMs\": 604800000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"timechart\"\n      },\n      \"name\": \"events-over-time\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"AzureActivity\\n| summarize Operations = count() by Caller\\n| top 10 by Operations desc\",\n        \"size\": 0,\n        \"title\": \"Top 10 callers\",\n        \"timeContext\": { \"durationMs\": 604800000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"barchart\"\n      },\n      \"name\": \"top-callers\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"AzureActivity\\n| where ActivityStatusValue in ('Failed', 'Failure')\\n| summarize Failures = count() by OperationNameValue, ResourceGroup\\n| top 15 by Failures desc\",\n        \"size\": 0,\n        \"title\": \"Failed operations\",\n        \"timeContext\": { \"durationMs\": 604800000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"table\"\n      },\n      \"name\": \"failed-ops\"\n    }\n  ],\n  \"$schema\": \"https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json\"\n}\n",
            "$fxv#1": "{\n  \"version\": \"Notebook/1.0\",\n  \"items\": [\n    {\n      \"type\": 1,\n      \"content\": {\n        \"json\": \"# Sentinel — Ingestion & Alert Health (Lab)\\nData volume by table and security alerts by severity. Useful for keeping a lab workspace within its daily ingestion cap.\"\n      },\n      \"name\": \"title\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"Usage\\n| where IsBillable == true\\n| summarize IngestedGB = round(sum(Quantity) / 1000, 3) by DataType\\n| top 15 by IngestedGB desc\",\n        \"size\": 0,\n        \"title\": \"Billable ingestion by table (GB)\",\n        \"timeContext\": { \"durationMs\": 2592000000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"barchart\"\n      },\n      \"name\": \"ingest-by-table\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"SecurityAlert\\n| summarize Alerts = count() by AlertSeverity\\n| order by Alerts desc\",\n        \"size\": 0,\n        \"title\": \"Security alerts by severity\",\n        \"timeContext\": { \"durationMs\": 2592000000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"piechart\"\n      },\n      \"name\": \"alerts-by-severity\"\n    },\n    {\n      \"type\": 3,\n      \"content\": {\n        \"version\": \"KqlItem/1.0\",\n        \"query\": \"union withsource=TableName *\\n| where TimeGenerated > ago(24h)\\n| summarize Records = count() by TableName\\n| top 20 by Records desc\",\n        \"size\": 0,\n        \"title\": \"Records ingested in the last 24h by table\",\n        \"timeContext\": { \"durationMs\": 86400000 },\n        \"queryType\": 0,\n        \"resourceType\": \"microsoft.operationalinsights/workspaces\",\n        \"visualization\": \"table\"\n      },\n      \"name\": \"records-24h\"\n    }\n  ],\n  \"$schema\": \"https://github.com/Microsoft/Application-Insights-Workbooks/blob/master/schema/workbook.json\"\n}\n"
          },
